# MongoDB Atlas connection string (optional).
# If set, Pipeline A and B will read/write account memos and agent specs to MongoDB
# instead of local files. Leave unset to use file-based storage under outputs/.
#
# Get your connection string from: MongoDB Atlas -> Cluster -> Connect -> Drivers
# Example (do not commit your real URI):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

MONGODB_URI=
